            "type": "timeseries",
            "targets": [
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "${datasource}"
                    },
                    "expr": "histogram_quantile(0.95, sum(rate(db_query_duration_seconds_bucket{job=\"backend\", environment=\"$environment\"}[5m])) by (le, domain))",
                    "legendFormat": "{{domain}}",
                    "refId": "A"
                }
            ]
        },
        {
            "datasource": {
                "type": "prometheus",
                "uid": "${datasource}"
            },
            "fieldConfig": {
                "defaults": {
                    "custom": {
                        "drawStyle": "line",
                        "fillOpacity": 10,
                        "lineWidth": 2,
                        "pointSize": 5,
                        "showPoints": "never"
                    },
                    "unit": "s"
                },
                "overrides": []
            },
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 8
            },
            "id": 9,
            "options": {
                "legend": {
                    "displayMode": "list",
                    "placement": "bottom"
                },
                "tooltip": {
                    "mode": "multi",
                    "sort": "desc"
                }
            },
            "title": "Query Duration P50 vs P99",
            "type": "timeseries",
            "targets": [
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "${datasource}"
                    },
                    "expr": "histogram_quantile(0.5, sum(rate(db_query_duration_seconds_bucket{job=\"backend\", environment=\"$environment\"}[5m])) by (le))",
                    "legendFormat": "P50",
                    "refId": "A"
                },
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "${datasource}"
                    },
                    "expr": "histogram_quantile(0.99, sum(rate(db_query_duration_seconds_bucket{job=\"backend\", environment=\"$environment\"}[5m])) by (le))",
                    "legendFormat": "P99",
                    "refId": "B"
                }
            ]
        },
        {
            "datasource": {
                "type": "prometheus",
                "uid": "${datasource}"
            },
            "fieldConfig": {
                "defaults": {
                    "custom": {
                        "drawStyle": "bars",
                        "fillOpacity": 80,
                        "lineWidth": 1,
                        "pointSize": 5,
                        "showPoints": "never",
                        "stacking": {
                            "mode": "normal",
                            "group": "A"
                        }
                    },
                    "unit": "ops"
                },
                "overrides": []
            },
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 16
            },
            "id": 10,
            "options": {
                "legend": {
                    "displayMode": "list",
                    "placement": "bottom"
                },
                "tooltip": {
                    "mode": "multi",
                    "sort": "desc"
                }
            },
            "title": "Queries/sec by Domain",
            "type": "timeseries",
            "targets": [
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "${datasource}"
                    },
                    "expr": "sum(rate(db_query_duration_seconds_count{job=\"backend\", environment=\"$environment\"}[5m])) by (domain)",
                    "legendFormat": "{{domain}}",
                    "refId": "A"
                }
            ]
        },
        {
            "datasource": {
                "type": "prometheus",
                "uid": "${datasource}"
            },
            "fieldConfig": {
                "defaults": {
                    "custom": {
                        "filterable": true
                    },
                    "unit": "s"
                },
                "overrides": []
            },
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 16
            },
            "id": 11,
            "options": {
                "showHeader": true,
                "sortBy": [
                    {
                        "desc": true,
                        "displayName": "P95"
                    }
                ]
            },
            "title": "Slowest Domains (P95)",
            "type": "table",
            "targets": [
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "${datasource}"
                    },
                    "expr": "histogram_quantile(0.95, sum(rate(db_query_duration_seconds_bucket{job=\"backend\", environment=\"$environment\"}[5m])) by (le, domain))",
                    "format": "table",
                    "instant": true,
                    "legendFormat": "",
                    "refId": "A"
                }
            ],
            "transformations": [
                {
                    "id": "organize",
                    "options": {
                        "excludeByName": {
                            "Time": true,
                            "le": true
                        },
                        "renameByName": {
                            "domain": "Domain",
                            "Value": "P95"
                        }
                    }
                }
            ]
        },
        {
            "datasource": {
                "type": "prometheus",
                "uid": "${datasource}"
            },
            "fieldConfig": {
                "defaults": {
                    "custom": {
                        "hideFrom": {
                            "legend": false,
                            "tooltip": false,
                            "viz": false
                        }
                    }
                },
                "overrides": []
