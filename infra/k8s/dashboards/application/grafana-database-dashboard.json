            "gridPos": {
                "h": 8,
                "w": 24,
                "x": 0,
                "y": 24
            },
            "id": 12,
            "options": {
                "calculate": true,
                "calculation": {
                    "xBuckets": {
                        "mode": "size"
                    }
                },
                "cellGap": 1,
                "color": {
                    "mode": "scheme",
                    "scheme": "Spectral",
                    "steps": 64
                },
                "yAxis": {
                    "unit": "s"
                }
            },
            "title": "Query Duration Heatmap",
            "type": "heatmap",
            "targets": [
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "${datasource}"
                    },
                    "expr": "sum(increase(db_query_duration_seconds_bucket{job=\"backend\", environment=\"$environment\"}[5m])) by (le)",
                    "format": "heatmap",
                    "legendFormat": "{{le}}",
                    "refId": "A"
                }
            ]
        }
    ],
