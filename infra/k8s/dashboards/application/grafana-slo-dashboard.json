                            },
                            {
                                "color": "green",
                                "value": 95
                            }
                        ]
                    },
                    "unit": "percent",
                    "decimals": 2,
                    "min": 80
                },
                "overrides": []
            },
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 17
            },
            "id": 10,
            "options": {
                "legend": {
                    "displayMode": "list",
                    "placement": "bottom"
                },
                "tooltip": {
                    "mode": "multi",
                    "sort": "desc"
                }
            },
            "title": "Latency SLO Over Time (rolling 1h, % < 500ms)",
            "type": "timeseries",
            "targets": [
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "${datasource}"
                    },
                    "expr": "sum(rate(api_http_requests_duration_seconds_bucket{job=\"backend\", environment=\"$environment\", le=\"0.5\"}[1h])) / sum(rate(api_http_requests_duration_seconds_count{job=\"backend\", environment=\"$environment\"}[1h])) * 100",
                    "legendFormat": "% requests < 500ms",
                    "refId": "A"
                }
            ]
        }
    ],
