                },
                "tooltip": {
                    "mode": "multi",
                    "sort": "desc"
                }
            },
            "title": "Availability Over Time (rolling 1h)",
            "type": "timeseries",
            "targets": [
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "${datasource}"
                    },
                    "expr": "(1 - (sum(rate(api_http_requests_total{job=\"backend\", environment=\"$environment\", status=~\"5..\"}[1h])) / sum(rate(api_http_requests_total{job=\"backend\", environment=\"$environment\"}[1h])))) * 100",
                    "legendFormat": "Availability %",
                    "refId": "A"
                }
            ]
        },
        {
            "datasource": {
                "type": "prometheus",
                "uid": "${datasource}"
            },
            "fieldConfig": {
                "defaults": {
                    "custom": {
                        "drawStyle": "line",
                        "fillOpacity": 5,
                        "lineWidth": 2,
                        "pointSize": 5,
