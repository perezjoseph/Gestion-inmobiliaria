                            },
                            {
                                "color": "red",
                                "value": 14.4
                            }
                        ]
                    },
                    "unit": "short",
                    "decimals": 2
                },
                "overrides": []
            },
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 8
            },
            "id": 7,
            "options": {
                "legend": {
                    "displayMode": "list",
                    "placement": "bottom"
                },
                "tooltip": {
                    "mode": "multi",
                    "sort": "desc"
                }
            },
            "title": "Latency Burn Rate (1h window)",
            "type": "timeseries",
            "targets": [
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "${datasource}"
                    },
                    "expr": "(1 - (sum(rate(api_http_requests_duration_seconds_bucket{job=\"backend\", environment=\"$environment\", le=\"0.5\"}[1h])) / sum(rate(api_http_requests_duration_seconds_count{job=\"backend\", environment=\"$environment\"}[1h])))) / 0.05",
                    "legendFormat": "1h burn rate",
                    "refId": "A"
                },
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "${datasource}"
                    },
                    "expr": "(1 - (sum(rate(api_http_requests_duration_seconds_bucket{job=\"backend\", environment=\"$environment\", le=\"0.5\"}[6h])) / sum(rate(api_http_requests_duration_seconds_count{job=\"backend\", environment=\"$environment\"}[6h])))) / 0.05",
                    "legendFormat": "6h burn rate",
                    "refId": "B"
                }
            ]
        },
        {
            "collapsed": false,
            "gridPos": {
                "h": 1,
                "w": 24,
                "x": 0,
                "y": 16
            },
            "id": 8,
            "title": "SLO Trend",
            "type": "row"
        },
        {
            "datasource": {
