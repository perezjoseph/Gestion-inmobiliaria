{
    "annotations": {
        "list": [
            {
                "builtIn": 1,
                "datasource": {
                    "type": "grafana",
                    "uid": "-- Grafana --"
                },
                "enable": true,
                "hide": true,
                "iconColor": "rgba(0, 211, 255, 1)",
                "name": "Annotations & Alerts",
                "type": "dashboard"
            }
        ]
    },
    "editable": true,
    "fiscalYearStartMonth": 0,
    "graphTooltip": 1,
    "id": null,
    "links": [],
    "panels": [
        {
            "collapsed": false,
            "gridPos": {
                "h": 1,
                "w": 24,
                "x": 0,
                "y": 0
            },
            "id": 1,
            "title": "WhatsApp Connectivity (baileys)",
            "type": "row"
        },
        {
            "datasource": {
                "type": "prometheus",
                "uid": "${datasource}"
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "short",
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "red",
                                "value": null
                            },
                            {
                                "color": "green",
                                "value": 1
                            }
                        ]
                    }
                },
                "overrides": []
            },
            "gridPos": {
                "h": 6,
                "w": 6,
                "x": 0,
                "y": 1
            },
            "id": 2,
            "options": {
                "colorMode": "value",
                "graphMode": "area",
                "reduceOptions": {
                    "calcs": [
                        "lastNotNull"
                    ],
                    "fields": "",
                    "values": false
                }
            },
            "title": "Connected Realms",
            "type": "stat",
            "targets": [
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "${datasource}"
                    },
                    "expr": "sum(whatsapp_connection_up)",
                    "legendFormat": "connected",
                    "refId": "A"
                }
            ]
        },
        {
            "datasource": {
                "type": "prometheus",
                "uid": "${datasource}"
            },
            "fieldConfig": {
                "defaults": {
                    "mappings": [
                        {
                            "type": "value",
                            "options": {
                                "0": {
                                    "text": "DOWN",
                                    "color": "red"
                                },
                                "1": {
                                    "text": "UP",
                                    "color": "green"
                                }
                            }
                        }
                    ]
                },
                "overrides": []
            },
            "gridPos": {
                "h": 6,
                "w": 18,
                "x": 6,
                "y": 1
            },
            "id": 3,
            "options": {
                "showValue": "auto",
                "mergeValues": true,
                "alignValue": "left"
            },
            "title": "Per-Realm Connection State",
            "type": "state-timeline",
            "targets": [
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "${datasource}"
                    },
                    "expr": "whatsapp_connection_up",
                    "legendFormat": "{{realm}}",
                    "refId": "A"
                }
            ]
        },
        {
            "datasource": {
                "type": "prometheus",
                "uid": "${datasource}"
            },
            "fieldConfig": {
                "defaults": {
                    "custom": {
                        "drawStyle": "line",
                        "fillOpacity": 10
                    },
                    "unit": "mps"
                },
                "overrides": []
            },
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 7
            },
            "id": 4,
            "options": {
                "legend": {
                    "displayMode": "table",
                    "placement": "bottom",
                    "calcs": [
                        "mean",
                        "lastNotNull"
                    ]
                },
                "tooltip": {
                    "mode": "multi"
                }
            },
            "title": "Message Throughput by Direction",
            "type": "timeseries",
            "targets": [
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "${datasource}"
                    },
                    "expr": "sum by (direction) (rate(whatsapp_messages_total[5m]))",
                    "legendFormat": "{{direction}}",
                    "refId": "A"
                }
            ]
        },
        {
            "datasource": {
                "type": "prometheus",
                "uid": "${datasource}"
            },
            "fieldConfig": {
                "defaults": {
                    "custom": {
                        "drawStyle": "line",
                        "fillOpacity": 10
                    },
                    "unit": "mps"
                },
                "overrides": []
            },
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 7
            },
            "id": 5,
            "options": {
                "legend": {
                    "displayMode": "table",
                    "placement": "bottom",
                    "calcs": [
                        "sum"
                    ]
                },
                "tooltip": {
                    "mode": "multi"
                }
            },
            "title": "Message Errors by Direction",
            "type": "timeseries",
            "targets": [
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "${datasource}"
                    },
                    "expr": "sum by (direction) (rate(whatsapp_messages_total{status=\"error\"}[5m]))",
                    "legendFormat": "{{direction}}",
                    "refId": "A"
                }
            ]
        },
        {
            "datasource": {
                "type": "prometheus",
                "uid": "${datasource}"
            },
            "fieldConfig": {
                "defaults": {
                    "custom": {
                        "drawStyle": "line",
                        "fillOpacity": 10
                    },
                    "unit": "short"
                },
                "overrides": []
            },
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 15
            },
            "id": 6,
            "options": {
                "legend": {
                    "displayMode": "table",
                    "placement": "bottom",
                    "calcs": [
                        "sum"
                    ]
                },
                "tooltip": {
                    "mode": "multi"
                }
            },
            "title": "Reconnect Rate by Realm",
            "type": "timeseries",
            "targets": [
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "${datasource}"
                    },
                    "expr": "rate(whatsapp_reconnects_total[5m])",
                    "legendFormat": "{{realm}}",
                    "refId": "A"
                }
            ]
        },
        {
            "datasource": {
                "type": "prometheus",
                "uid": "${datasource}"
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "short"
                },
                "overrides": []
            },
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 15
            },
            "id": 7,
            "options": {
                "legend": {
                    "displayMode": "table",
                    "placement": "bottom",
                    "calcs": [
                        "lastNotNull"
                    ]
                },
                "tooltip": {
                    "mode": "multi"
                }
            },
            "title": "Session Restore Outcomes",
            "type": "timeseries",
            "targets": [
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "${datasource}"
                    },
                    "expr": "whatsapp_session_restore_total",
                    "legendFormat": "{{result}}",
                    "refId": "A"
                }
            ]
        }
    ],
    "refresh": "30s",
    "schemaVersion": 39,
    "tags": [
        "whatsapp",
        "baileys",
        "application"
    ],
    "templating": {
        "list": [
            {
                "current": {},
                "hide": 0,
                "includeAll": false,
                "label": "Datasource",
                "multi": false,
                "name": "datasource",
                "options": [],
                "query": "prometheus",
                "queryValue": "",
                "refresh": 1,
                "regex": "",
                "skipUrlSync": false,
                "type": "datasource"
            }
        ]
    },
    "time": {
        "from": "now-6h",
        "to": "now"
    },
    "timepicker": {},
    "timezone": "",
    "title": "WhatsApp (baileys)",
    "uid": "whatsapp-baileys",
    "version": 1,
    "weekStart": ""
}