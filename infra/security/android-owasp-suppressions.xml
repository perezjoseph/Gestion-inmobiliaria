<?xml version="1.0" encoding="UTF-8"?>
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">
    <!--
        OWASP Dependency-Check suppression file for the Android CI pipeline.
        Add entries here for confirmed false positives only.
        Each suppression MUST include a <notes> explaining why it is safe.
        Review this file periodically and remove entries for resolved CVEs.
    -->

    <!-- detekt is a build-time static analysis tool. Its transitive SnakeYAML
         dependency is only used to parse detekt's own YAML config files, never
         untrusted user input. These CVEs require attacker-controlled YAML input
         to exploit, which is not possible in a CI/build-only context. -->
    <suppress>
        <notes><![CDATA[
            CVE-2022-1471: SnakeYAML RCE via unsafe deserialization.
            Not exploitable: detekt is a build-time linter that only parses its
            own config files. No untrusted YAML is ever processed.
        ]]></notes>
        <cve>CVE-2022-1471</cve>
    </suppress>
    <suppress>
        <notes><![CDATA[
            CVE-2022-25857: SnakeYAML DoS via deeply nested collections.
            Not exploitable: same reasoning as CVE-2022-1471 above.
        ]]></notes>
        <cve>CVE-2022-25857</cve>
    </suppress>
</suppressions>
