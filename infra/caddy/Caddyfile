# To switch to Let's Encrypt: replace "localhost:8443" with your domain
# and replace "tls internal" with "tls your@email.com"

gestion.local:8443 {
	tls internal

	handle /health {
		respond "OK" 200
	}

	handle /api/* {
		reverse_proxy backend:8080
	}

	handle /uploads/* {
		reverse_proxy backend:8080
	}

	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}
