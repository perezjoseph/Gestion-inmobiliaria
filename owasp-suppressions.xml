        <packageUrl regex="true">^pkg:cargo/ttf-parser@.*$</packageUrl>
        <cpe regex="true">cpe:/a:.*:(freetype|harfbuzz|fontforge|ttf):.*</cpe>
    </suppress>
    <suppress>
        <notes>owned_ttf_parser false positive - wrapper around ttf-parser</notes>
        <packageUrl regex="true">^pkg:cargo/owned_ttf_parser@.*$</packageUrl>
        <cpe regex="true">cpe:/a:.*:(freetype|harfbuzz|fontforge|ttf):.*</cpe>
    </suppress>

    <!-- brotli crate matched against Google Brotli C library CVEs -->
    <suppress>
