    <suppress>
        <notes>ring crate false positive - Rust crypto, not unrelated ring software</notes>
        <packageUrl regex="true">^pkg:cargo/ring@.*$</packageUrl>
        <cpe regex="true">cpe:/a:.*:ring:.*</cpe>
    </suppress>

