<?xml version="1.0" encoding="UTF-8"?>
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">

    <!-- h2 0.3.x: CVE-2024-27316 / RUSTSEC-2024-0332 (CONTINUATION Flood, CVSS 7.5).
         Pinned by actix-http 3.x — cannot upgrade without actix-web 5.x (not yet stable).
         Mitigated: actix-governor rate limiting and actix-web connection handling limits. -->
    <suppress>
        <notes>h2 0.3.x CONTINUATION Flood - pinned by actix-http 3.x, mitigated by rate limiting</notes>
        <packageUrl regex="true">^pkg:cargo/h2@0\.3\..*$</packageUrl>
        <cve>CVE-2024-27316</cve>
    </suppress>
    <suppress>
        <notes>h2 0.3.x resource exhaustion - pinned by actix-http 3.x</notes>
        <packageUrl regex="true">^pkg:cargo/h2@0\.3\..*$</packageUrl>
        <cve>CVE-2024-25510</cve>
    </suppress>

    <!-- rsa 0.9.x: Marvin Attack timing sidechannel (CVSS 5.9 medium).
         No patched version available. We use HMAC-based JWTs, not RSA keys. -->
    <suppress>
        <notes>rsa Marvin Attack - not exploitable, we use HMAC JWTs not RSA</notes>
        <packageUrl regex="true">^pkg:cargo/rsa@0\.9\..*$</packageUrl>
        <cve>CVE-2023-49092</cve>
    </suppress>

    <!-- ══════════════════════════════════════════════════════════════════
         FALSE POSITIVE CPE SUPPRESSIONS
         OWASP Dependency-Check with enableExperimental aggressively matches
         Rust crate names against NVD CPE entries for unrelated C/C++/Java
         software. These are name-collision false positives only.
         Actual Rust vulnerabilities are caught by cargo-audit (RustSec DB).
         ══════════════════════════════════════════════════════════════════ -->

    <!-- ring crate matched against unrelated "ring" software -->
    <suppress>
        <notes>ring crate false positive - Rust crypto, not unrelated ring software</notes>
        <packageUrl regex="true">^pkg:cargo/ring@.*$</packageUrl>
        <cpe regex="true">cpe:/a:.*:ring:.*</cpe>
    </suppress>

    <!-- Rust openssl-sys/openssl crate matched against OpenSSL C library CVEs -->
    <suppress>
        <notes>Rust openssl crate false positive CPE match against C OpenSSL</notes>
        <packageUrl regex="true">^pkg:cargo/.*$</packageUrl>
        <cpe regex="true">cpe:/a:openssl:openssl:.*</cpe>
    </suppress>

    <!-- h2 crate matched against H2 Java database -->
    <suppress>
        <notes>h2 crate false positive - Rust HTTP/2, not H2 Java database</notes>
        <packageUrl regex="true">^pkg:cargo/h2@.*$</packageUrl>
        <cpe regex="true">cpe:/a:h2database:h2:.*</cpe>
    </suppress>

    <!-- cookie crate matched against unrelated cookie-handling CVEs -->
    <suppress>
        <notes>cookie crate false positive - Rust HTTP cookie crate</notes>
        <packageUrl regex="true">^pkg:cargo/cookie@.*$</packageUrl>
        <cpe regex="true">cpe:/a:.*:cookie:.*</cpe>
    </suppress>

    <!-- url crate matched against unrelated URL parsing CVEs -->
    <suppress>
        <notes>url crate false positive - Rust URL parser</notes>
        <packageUrl regex="true">^pkg:cargo/url@.*$</packageUrl>
        <cpe regex="true">cpe:/a:.*:url:.*</cpe>
    </suppress>

    <!-- idna crate matched against unrelated IDNA implementations -->
    <suppress>
        <notes>idna crate false positive - Rust IDNA implementation</notes>
        <packageUrl regex="true">^pkg:cargo/idna@.*$</packageUrl>
        <cpe regex="true">cpe:/a:.*:idna:.*</cpe>
    </suppress>

    <!-- rustls matched against OpenSSL/GnuTLS/other TLS CVEs -->
    <suppress>
        <notes>rustls false positive - pure Rust TLS, not OpenSSL/GnuTLS</notes>
        <packageUrl regex="true">^pkg:cargo/rustls@.*$</packageUrl>
        <cpe regex="true">cpe:/a:.*:(openssl|gnutls|libressl|boringssl|wolfssl|mbedtls):.*</cpe>
    </suppress>

    <!-- rsa crate matched against OpenSSL RSA CVEs -->
    <suppress>
        <notes>rsa crate false positive - pure Rust RSA, not OpenSSL</notes>
        <packageUrl regex="true">^pkg:cargo/rsa@.*$</packageUrl>
        <cpe regex="true">cpe:/a:openssl:openssl:.*</cpe>
    </suppress>

    <!-- http crate matched against HTTP server/client CVEs -->
    <suppress>
        <notes>http crate false positive - Rust HTTP types library, not a server</notes>
        <packageUrl regex="true">^pkg:cargo/http@.*$</packageUrl>
        <cpe regex="true">cpe:/a:.*:http:.*</cpe>
    </suppress>

    <!-- tokio matched against unrelated software named tokio -->
    <suppress>
        <notes>tokio false positive CPE match</notes>
        <packageUrl regex="true">^pkg:cargo/tokio@.*$</packageUrl>
        <cpe regex="true">cpe:/a:.*:tokio:.*</cpe>
    </suppress>

    <!-- regex crate matched against PCRE/Oniguruma CVEs -->
    <suppress>
        <notes>regex crate false positive - Rust regex engine, not PCRE</notes>
        <packageUrl regex="true">^pkg:cargo/regex@.*$</packageUrl>
        <cpe regex="true">cpe:/a:.*:regex:.*</cpe>
    </suppress>

    <!-- csv crate matched against unrelated CSV software -->
    <suppress>
        <notes>csv crate false positive CPE match</notes>
        <packageUrl regex="true">^pkg:cargo/csv@.*$</packageUrl>
        <cpe regex="true">cpe:/a:csv_project:csv:.*</cpe>
    </suppress>

    <!-- md5 crate matched against MD5 hash algorithm weakness CVEs.
         Used internally by numaelis-rckive-genpdf for PDF object IDs, not for security. -->
    <suppress>
        <notes>md5 crate false positive - used for PDF internals, not cryptographic security</notes>
        <packageUrl regex="true">^pkg:cargo/md5@.*$</packageUrl>
        <cpe regex="true">cpe:/a:.*:md5:.*</cpe>
    </suppress>

