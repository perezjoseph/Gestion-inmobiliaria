        <packageUrl regex="true">^pkg:cargo/brotli@.*$</packageUrl>
        <cpe regex="true">cpe:/a:.*:brotli:.*</cpe>
    </suppress>
    <suppress>
        <notes>brotli-decompressor false positive</notes>
        <packageUrl regex="true">^pkg:cargo/brotli-decompressor@.*$</packageUrl>
        <cpe regex="true">cpe:/a:.*:brotli:.*</cpe>
