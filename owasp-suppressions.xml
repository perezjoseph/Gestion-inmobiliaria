<?xml version="1.0" encoding="UTF-8"?>
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">

    <!-- h2 0.3.x: CVE-2024-27316 / RUSTSEC-2024-0332 (CONTINUATION Flood, CVSS 7.5).
         Pinned by actix-http 3.x — cannot upgrade without actix-web 5.x (not yet stable).
         Mitigated: actix-governor rate limiting and actix-web connection handling limits. -->
    <suppress>
        <notes>h2 0.3.x CONTINUATION Flood - pinned by actix-http 3.x, mitigated by rate limiting</notes>
        <packageUrl regex="true">^pkg:cargo/h2@0\.3\..*$</packageUrl>
        <cve>CVE-2024-27316</cve>
    </suppress>
    <suppress>
        <notes>h2 0.3.x resource exhaustion - pinned by actix-http 3.x</notes>
        <packageUrl regex="true">^pkg:cargo/h2@0\.3\..*$</packageUrl>
        <cve>CVE-2024-25510</cve>
    </suppress>

    <!-- rsa 0.9.x: Marvin Attack timing sidechannel (CVSS 5.9 medium).
         No patched version available. We use HMAC-based JWTs, not RSA keys. -->
    <suppress>
        <notes>rsa Marvin Attack - not exploitable, we use HMAC JWTs not RSA</notes>
        <packageUrl regex="true">^pkg:cargo/rsa@0\.9\..*$</packageUrl>
        <cve>CVE-2023-49092</cve>
    </suppress>

    <!-- ══════════════════════════════════════════════════════════════════
         FALSE POSITIVE CPE SUPPRESSIONS
         OWASP Dependency-Check with enableExperimental aggressively matches
         Rust crate names against NVD CPE entries for unrelated C/C++/Java
         software. These are name-collision false positives only.
         Actual Rust vulnerabilities are caught by cargo-audit (RustSec DB).
         ══════════════════════════════════════════════════════════════════ -->

