DATABASE_URL=postgresql://realestate:realestate_dev_password@localhost:5432/realestate
JWT_SECRET=your_jwt_secret_here_change_in_production
SERVER_PORT=8080
CORS_ORIGIN=http://localhost:8080

# Connection Pool
DB_MAX_CONNECTIONS=10
DB_MIN_CONNECTIONS=2
DB_CONNECT_TIMEOUT_SECS=5
DB_IDLE_TIMEOUT_SECS=300
DB_MAX_LIFETIME_SECS=1800
DB_SQLX_LOGGING=false

# GitHub Actions Runner (docker-compose.runner.yml)
GITHUB_REPO_URL=https://github.com/<owner>/<repo>
GITHUB_RUNNER_TOKEN=your_github_pat_here

# Webhook Listener
WEBHOOK_SECRET=your_webhook_secret_here
BIND_ADDRESS=0.0.0.0  # 0.0.0.0 to accept LAN connections; only 192.168.88.0/24 and loopback are allowed