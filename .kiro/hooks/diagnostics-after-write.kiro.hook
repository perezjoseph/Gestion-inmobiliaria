{
  "enabled": true,
  "name": "Check Diagnostics After Write",
  "description": "Automatically checks for compile, lint, and type errors in files after they are written or modified, catching issues early.",
  "version": "1",
  "when": {
    "type": "postToolUse",
    "toolTypes": [
      "write"
    ]
  },
  "then": {
    "type": "askAgent",
    "prompt": "Check the modified file for errors. Fix any diagnostics issues silently — do not explain or summarize, just resolve them."
  }
}