{
  "enabled": true,
  "name": "Post-Task Compile Check",
  "description": "Runs cargo check before any write tool executes to ensure the workspace compiles before changes",
  "version": "1",
  "when": {
    "type": "postTaskExecution"
  },
  "then": {
    "type": "runCommand",
    "command": "cargo check --workspace"
  },
  "workspaceFolderName": "realestate",
  "shortName": "pre-tool-check"
}