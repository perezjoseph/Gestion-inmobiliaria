{
  "enabled": true,
  "name": "SkillSpector Security Scan",
  "description": "Scans new skill files for security vulnerabilities using SkillSpector static analysis (no LLM).",
  "version": "1.0.0",
  "when": {
    "type": "fileCreated",
    "patterns": [
      ".kiro/skills/**"
    ]
  },
  "then": {
    "type": "askAgent",
    "prompt": "A new file was just created in .kiro/skills/. Run SkillSpector to scan the skill's directory for security vulnerabilities. Run: d:\\realestate\\.venv\\Scripts\\skillspector.exe scan <skill_directory> --no-llm --format terminal. Report risk score and findings. If HIGH or CRITICAL, warn user to NOT use the skill and suggest removal."
  }
}