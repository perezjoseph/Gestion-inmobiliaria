{
  "enabled": true,
  "name": "Post Tool Formatter ",
  "description": "When a Rust file is edited, runs cargo fmt and cargo clippy on the workspace to ensure consistent code style and quality.",
  "version": "1",
  "when": {
    "type": "postToolUse",
    "toolTypes": [
      "write"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "cargo fmt --all",
    "timeout": 120
  },
  "workspaceFolderName": "realestate",
  "shortName": "post-tool-fmt-lint"
}