{
  "name": "Orchestrator — On Agent Stop",
  "version": "1",
  "description": "Runs a final orchestrator pass in the background when the main agent stops",
  "when": {
    "type": "agentStop"
  },
  "then": {
    "type": "runCommand",
    "command": "wsl -u jperez -d Ubuntu-22.04 bash -lc \"bash .kiro/run-orchestrator-agent.sh\""
  }
}
