{
  "enabled": true,
  "name": "Optimization Agent — On Agent Stop",
  "description": "Runs a final optimization pass in the background when the main agent stops",
  "version": "1",
  "when": {
    "type": "agentStop"
  },
  "then": {
    "type": "runCommand",
    "command": "start /b .kiro\\run-optimization-agent.cmd"
  }
}
