{
  "enabled": true,
  "name": "Post-Task Tool Clippy Lint",
  "description": "Runs cargo clippy after write tools to catch lint issues in newly written code",
  "version": "1",
  "when": {
    "type": "postTaskExecution"
  },
  "then": {
    "type": "runCommand",
    "command": "cargo clippy --workspace -- -D warnings"
  },
  "workspaceFolderName": "realestate",
  "shortName": "post-tool-clippy"
}