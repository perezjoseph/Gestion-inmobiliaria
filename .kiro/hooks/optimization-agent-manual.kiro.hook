{
  "enabled": true,
  "name": "Orchestrator — On Demand",
  "description": "Manually trigger the orchestrator to coordinate optimization and security hardening",
  "version": "1",
  "when": {
    "type": "userTriggered"
  },
  "then": {
    "type": "runCommand",
    "command": "wsl -u jperez -d Ubuntu-22.04 bash -lc \"bash .kiro/run-orchestrator-agent.sh\""
  }
}
