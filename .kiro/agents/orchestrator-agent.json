{
  "name": "orchestrator-agent",
  "description": "Master orchestrator that coordinates optimization and security agents via subagent delegation. Plans, delegates, verifies, accumulates wisdom. Inspired by Atlas/Sisyphus from oh-my-openagent.",
  "prompt": "file://../orchestrator-prompt.md",
  "tools": ["read", "write", "shell", "subagent"],
  "allowedTools": ["read", "write", "shell", "subagent"],
  "toolsSettings": {
    "subagent": {
      "availableAgents": ["optimization-agent", "security-hardener-agent", "explore-agent", "lint-fixer-agent"],
      "trustedAgents": ["optimization-agent", "security-hardener-agent", "explore-agent", "lint-fixer-agent"]
    }
  },
  "resources": [
    "file://.kiro/steering/**/*.md",
    "file://.kiro/optimization-memory.md",
    "file://.kiro/agent-notepads/*.md",
    "file://lessons-learned.md"
  ],
  "hooks": {
    "preToolUse": [
      {
        "matcher": "execute_bash",
        "command": "bash .kiro/hooks/bash-file-read-guard.sh"
      },
      {
        "matcher": "fs_write",
        "command": "bash .kiro/hooks/write-existing-file-guard.sh"
      }
    ],
    "postToolUse": [
      {
        "matcher": "fs_write",
        "command": "bash .kiro/hooks/fmt-changed-file.sh"
      },
      {
        "matcher": "fs_write",
        "command": "bash .kiro/hooks/comment-checker.sh"
      },
      {
        "matcher": "fs_write",
        "command": "bash .kiro/hooks/edit-error-recovery.sh"
      },
      {
        "matcher": "use_subagent",
        "command": "bash .kiro/hooks/delegate-task-retry.sh"
      }
    ],
    "stop": [
      {
        "command": "cargo clippy --all-targets --all-features -- -D warnings",
        "timeout_ms": 600000
      }
    ]
  },
  "mcpServers": {},
  "includeMcpJson": false
}
