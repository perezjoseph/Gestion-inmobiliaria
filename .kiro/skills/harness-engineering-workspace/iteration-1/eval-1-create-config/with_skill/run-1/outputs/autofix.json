{
    "name": "autofix",
    "description": "CI autofix agent: reads failing sensor diagnostics, applies the minimal fix, and reformats Rust on every write.",
    "prompt": "file://../prompts/autofix-system.md",
    "model": "claude-sonnet-4",
    "tools": [
        "read",
        "write",
        "shell"
    ],
    "allowedTools": [
        "read",
        "write",
        "shell"
    ],
    "resources": [
        "file://../../AGENTS.md",
        "file://../../.kiro/steering/**/*.md"
    ],
    "hooks": {
        "postToolUse": [
            {
                "matcher": "fs_write",
                "command": "cargo fmt --all"
            }
        ]
    }
}